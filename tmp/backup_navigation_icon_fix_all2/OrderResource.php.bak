<?php

namespace App\Filament\AdminShining\Resources\Orders;

use App\Models\Order;
use App\Filament\AdminShining\Resources\Orders\Pages as Pages;
use Filament\Resources\Resource;
use BackedEnum; // ← 追加（重要）

class OrderResource extends Resource
{
    protected static ?string $model = Order::class;

    // ✅ 型を Filament v4 と完全一致に変更
    protected static ?string  = 'heroicon-o-user-group';

    protected static ?string $navigationLabel = '注文一覧';

    public static function form(\Filament\Forms\Form $form): \Filament\Forms\Form
    {
        return $form->schema([]);
    }

    public static function table(\Filament\Tables\Table $table): \Filament\Tables\Table
    {
        return $table
            ->columns([
                \Filament\Tables\Columns\TextColumn::make('id')->label('ID'),
                \Filament\Tables\Columns\TextColumn::make('name')->label('名前'),
                \Filament\Tables\Columns\TextColumn::make('total_amount')->label('合計金額')->money('jpy'),
                \Filament\Tables\Columns\TextColumn::make('status')->label('ステータス'),
                \Filament\Tables\Columns\TextColumn::make('created_at')->label('作成日時')->dateTime(),
            ])
            ->filters([])
            ->actions([
                \Filament\Tables\Actions\ViewAction::make(),
                \Filament\Tables\Actions\EditAction::make(),
            ]);
    }

    public static function getPages(): array
    {
        return [
            'index' => Pages\ListOrders::route('/'),
            'create' => Pages\CreateOrder::route('/create'),
            'edit' => Pages\EditOrder::route('/{record}/edit'),
        ];
    }
}
