#!/usr/bin/env php
<?php

use Illuminate\Foundation\Application;
use Illuminate\Contracts\Console\Kernel;
use Symfony\Component\Console\Input\ArgvInput;
use Symfony\Component\Console\Output\ConsoleOutput;

define('LARAVEL_START', microtime(true));

require __DIR__ . '/vendor/autoload.php';

/*
 * Support both Laravel 12+ and Laravel <=10 CLI bootstrap.
 * - If the Application::handleCommand static helper exists (Laravel 12+), call it.
 * - Otherwise fall back to the traditional bootstrap for older Laravel versions.
 */
if (method_exists(Application::class, 'handleCommand')) {
    // Laravel 12+ unified CLI entry
    Application::handleCommand();
    exit(0);
}

/*
 * Traditional Laravel <=10 artisan bootstrap
 */
$app = require_once __DIR__ . '/bootstrap/app.php';

/** @var \Illuminate\Contracts\Console\Kernel $kernel */
$kernel = $app->make(Kernel::class);

$status = $kernel->handle(
    $input = new ArgvInput(),
    new ConsoleOutput()
);

$kernel->terminate($input, $status);

exit($status);
