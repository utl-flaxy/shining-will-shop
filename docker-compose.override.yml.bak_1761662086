services:
  worker:
    image: 'sail-8.4/app'
    working_dir: /var/www/html
    environment:
      APP_ENV: 'local'
      COMPOSER_ALLOW_SUPERUSER: '1'
      HOME: /var/www/html
    volumes:
      - ./:/var/www/html
    command: php artisan queue:work --sleep=3 --tries=3 --timeout=0
    restart: unless-stopped
    depends_on:
      - mysql
      - redis
